# 是否允许局域网
allow-lan: false
# 绑定地址
bind-address: 0.0.0.0
# 混合端口
mixed-port: 57878

# 运行模式
mode: rule
# 日志级别
log-level: warning
# ipv6
ipv6: true

# 进程匹配模式
find-process-mode: strict

# 外部控制 (API)
external-controller: 127.0.0.1:57890
# API 访问密钥
secret: "mihomo123456"
# 外部用户界面
external-ui: zashboard
# 外部用户界面下载地址
external-ui-url: https://github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip

profile:
  # 储存 API 对策略组的选择，以供下次启动时使用
  store-selected: true

# 统一延迟
unified-delay: true
# tcp 并发
tcp-concurrent: true

localdns: &localdns 127.0.0.1
localdns_ecs: &localdns_ecs 127.0.0.1#ecs=67.114.123.123/32
dns:
  # 启用dns模块
  enable: true
  # 启用ipv6 dns解析
  ipv6: true
  enhanced-mode: redir-host
  cache-algorithm: arc
  respect-rules: true
  # 默认dns, 用于解析dns服务器的域名
  default-nameserver:
    - *localdns
  # 代理节点域名解析服务器，仅用于解析代理节点的域名
  proxy-server-nameserver:
    - *localdns
  # 用于direct出口域名解析的dns服务器
  direct-nameserver:
    - *localdns
  nameserver:
    - *localdns_ecs
  nameserver-policy:
    "rule-set":
      - *localdns
    "geosite:geolocation-!cn":
      - https://1.1.1.1/dns-query
      - https://8.8.8.8/dns-query

# 代理集合
proxy-providers:
  daili:
    type: http
    url: {{ .daili_proxy_url }}
    path: proxy-providers/daili.yaml
    interval: 0
    override:
      udp-over-tcp: true
      udp-over-tcp-version: 2

proxies:
  - name: vless-us
    type: vless
    server: {{ .vless_server }}
    port: 443
    udp: true
    uuid: {{ .vless_us_uuid2 }}
    flow: xtls-rprx-vision
    packet-encoding: xudp
    tls: true
    servername: {{ .vless_sni2 }}
    client-fingerprint: chrome
    reality-opts:
      public-key: {{ .vless_public_key }}
      support-x25519mlkem768: true

  - name: xhttp-allin
    type: vless
    server: {{ .xhttp1_server }}
    port: 443
    udp: true
    packet-encoding: xudp
    uuid: {{ .xhttp_uuid }}
    tls: true
    network: xhttp
    flow: xtls-rprx-vision
    alpn: [h2]
    servername: {{ .xhttp1_server }}
    client-fingerprint: chrome
    encryption: {{ .vless_us_enc }}
    ech-opts:
      enable: true
    xhttp-opts:
      path: {{ .xhttp_path }}
      mode: auto
      reuse-settings:
        max-concurrency: 16-32
        c-max-reuse-times: 0
        h-max-request-times: 600-900
        h-max-reusable-secs: 1800-3000
        h-keep-alive-period: 0
      download-settings:
        path: {{ .xhttp_path }}
        server: {{ .xhttp_server }}
        servername: {{ .xhttp2_server }}

  - name: reality-up+xhttp-down
    type: vless
    server: {{ .vless_server }}
    port: 443
    udp: true
    uuid: {{ .xhttp_uuid }}
    flow: xtls-rprx-vision
    packet-encoding: xudp
    tls: true
    network: xhttp
    servername: {{ .vless_sni2 }}
    client-fingerprint: chrome
    encryption: {{ .vless_us_enc }}
    reality-opts:
      public-key: {{ .vless_public_key }}
      support-x25519mlkem768: true
    xhttp-opts:
      path: {{ .xhttp_path }}
      reuse-settings:
        max-concurrency: 16-32
        c-max-reuse-times: 0
        h-max-request-times: 600-900
        h-max-reusable-secs: 1800-3000
        h-keep-alive-period: 0
      download-settings:
        path: {{ .xhttp_path }}
        server: {{ .xhttp_server }}
        servername: {{ .xhttp2_server }}
        port: 443
        alpn: [h2]
        mode: auto
        reality-opts:
          public-key: ""

proxytest: &proxytest
  url: https://www.gstatic.com/generate_204
  interval: 0
  timeout: 2000
  max-failed-times: 5
  expected-status: 204

# 代理组
proxy-groups:
  - name: mainproxy
    type: select
    proxies:
      - xhttp-allin
      - reality-up+xhttp-down
      - vless-us
      - 美国
      - 日本
      - 新加坡
      - 香港
      - 台湾
      - 其它地区
      - 全部节点
      - DIRECT

  - name: 美国
    type: select
    filter: "(?i)美国|us|unitedstates|united states"
    <<: *proxytest
    use:
      - daili

  - name: 日本
    type: select
    filter: "(?i)日本|jp|japan"
    <<: *proxytest
    use:
     - daili

  - name: 新加坡
    type: select
    filter: "(?i)(新加坡|sg|singapore)"
    <<: *proxytest
    use:
      - daili

  - name: 香港
    type: select
    filter: "(?i)香港|hk|hongkong|hong kong"
    <<: *proxytest
    use:
      - daili

  - name: 台湾
    type: select
    filter: "(?i)台湾|tw|taiwan"
    <<: *proxytest
    use:
      - daili

  - name: 其它地区
    type: select
    filter: "(?i)^(?!.*(?:🇭🇰|🇯🇵|🇺🇸|🇸🇬|🇨🇳|香港|hk|hongkong|台湾|tw|taiwan|日本|jp|japan|新加坡|sg|singapore|美国|us|unitedstates)).*"
    <<: *proxytest
    use:
      - daili

  - name: 全部节点
    type: select
    <<: *proxytest
    use:
     - daili

rule-providers:
  icp:
    type: http
    path: rules/icp.mrs
    url: https://static-file-global.353355.xyz/rules/cn-additional-list.mrs
    interval: 43200
    proxy: DIRECT
    behavior: domain
    format: mrs

rules:
  - DOMAIN-SUFFIX,data.bilibili.com,REJECT
  # domain规则
  # 国内
  - GEOSITE,private,DIRECT
  - RULE-SET,icp,DIRECT
  - GEOSITE,CN,DIRECT
  # 国外
  - GEOSITE,geolocation-!cn,mainproxy

  # ip规则
  # 国内
  - GEOIP,private,DIRECT
  - GEOIP,CN,DIRECT
    ## 阿里云
  - IP-ASN,59055,DIRECT
  - IP-ASN,59054,DIRECT
  - IP-ASN,59053,DIRECT
  - IP-ASN,59052,DIRECT
  - IP-ASN,59051,DIRECT
  - IP-ASN,59028,DIRECT
  - IP-ASN,45104,DIRECT
  - IP-ASN,45103,DIRECT
  - IP-ASN,45102,DIRECT
  - IP-ASN,402207,DIRECT
  - IP-ASN,402205,DIRECT
  - IP-ASN,37963,DIRECT
  - IP-ASN,34947,DIRECT
  - IP-ASN,203513,DIRECT
  - IP-ASN,134963,DIRECT
  ## 腾讯云
  - IP-ASN,9390,DIRECT
  - IP-ASN,45090,DIRECT
  - IP-ASN,137876,DIRECT
  - IP-ASN,133478,DIRECT
  - IP-ASN,132591,DIRECT
  - IP-ASN,132203,DIRECT
  # 国外
